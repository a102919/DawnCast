# ── 執行環境 ──
# dev（預設，本機/測試）| prod。prod 會啟動上線防呆：拒絕預設 JWT secret 與 CORS '*'。
ENVIRONMENT=dev
# 允許的前端 origin（JSON 陣列）。prod 填真實網域，禁止 '*'。
CORS_ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
# CORS origin regex 補充（dotenv 格式，不寫 Python r""）。dev-only：用本機不走 vite proxy、
# 直接打後端時（例如 devtunnels 子網域）才需要。prod 留空，assert_secure() 會擋任何非空值。
CORS_ALLOWED_ORIGIN_REGEX=
# 夜間批次的日曆日錨點時區（worker 不用容器本機 UTC）。
APP_TIMEZONE=Asia/Taipei

# ── 資料庫（Supabase 託管 Postgres，service-role 連線）──
DATABASE_URL=postgresql://postgres:postgres@db.<project>.supabase.co:5432/postgres

# ── Auth（Supabase JWT；ES256 + JWKS）──
# 2025 起 Supabase 預設改 ES256，後端抓 JWKS 拿公鑰驗 token。prod 必設真實值，否則啟動即 fail。
SUPABASE_JWKS_URL=https://<project>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_AUDIENCE=authenticated
# Ops/admin endpoint（internal debug）驗證用固定 token，走 X-Admin-Token header 比對。
# prod 必設，否則啟動即 fail（不可用空字串）。
ADMIN_TOKEN=

# ── 生成引擎（PRD §8，env 一鍵切）──
GENERATION_ENGINE=api_key        # api_key | minimax
FAILOVER_MODE=degrade            # degrade | failover

# api_key fallback（MiniMax M2.5 / Anthropic 按量）
API_BASE_URL=https://api.minimax.io/anthropic
API_KEY=
API_MODEL=MiniMax-M2.5

# minimax 主引擎（OpenClaw 訂閱 token）
MINIMAX_ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
MINIMAX_AUTH_TOKEN=
MINIMAX_MODEL=MiniMax-M2.5
# MiniMax speech TTS（同一顆訂閱 token；未設 token 時整份 fallback edge-tts）
# MINIMAX_TTS_URL=https://api.minimax.io/v1/t2a_v2
# MINIMAX_TTS_MODEL=speech-02-turbo
# 推理模型（M2.5/M2.7）思考時間長，grounding prompt 變長後預設 30s read timeout
# 實測常不夠，正式環境建議調到 60-90s：
# HTTP_READ_TIMEOUT=90

# ── Cloudflare R2 ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=dawncast
R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com

# ── 真實資料來源（grounding，podcast 生成流程重新設計 Phase 1）──
# Tavily：使用者指定主題入口用搜尋，也給 news 入口補全文（免費 1000 credits/月，
# docs.tavily.com）。空值 → 自動降級成無 grounding，不擋生成。
TAVILY_API_KEY=
# Wikipedia：深度知識入口用，免 key，但 Wikimedia API 政策要求 User-Agent 帶真實聯絡方式。
WIKIPEDIA_USER_AGENT=DawnCast/1.0 (https://dawncast.app; contact: your-email@example.com)
# 以下皆有可用預設值，需要覆寫才填：
# GDELT_BASE_URL=https://api.gdeltproject.org/api/v2/doc/doc
# TAVILY_BASE_URL=https://api.tavily.com
# SOURCE_FETCH_TIMEOUT=10.0
# SOURCE_MAX_SNIPPETS=5
# LONG_PAUSE_SEC=0.7
