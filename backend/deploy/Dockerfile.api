# ── DawnCast API（FastAPI / uvicorn）───────────────────────────────────
# 對外服務層。不碰媒體處理，所以「不裝 ffmpeg、不裝中文字型」——
# 那些只有 worker 燒字幕時才需要，API 裝了只是讓 image 變肥、攻擊面變大。
#
# build context 為 backend/：所有 COPY 路徑相對 backend/。
# 例：docker build -f deploy/Dockerfile.api .

# ---- builder：用 uv 把依賴裝進 image 內的 .venv ----
FROM python:3.12-slim AS builder

# uv 官方靜態 binary，免在 image 裡裝 pip/curl
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

ENV UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy \
    UV_PYTHON_DOWNLOADS=0

WORKDIR /app

# 先只 COPY 依賴定義 → 鎖檔，命中 layer cache（原始碼變動不必重裝依賴）。
# --no-install-project：此時還沒 COPY 原始碼，只裝第三方依賴。
COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-dev --no-install-project

# 再 COPY 三個套件並安裝專案本身（API 只需 app + shared，
# 但 hatch wheel 把 app/engine/shared 綁同一包，故一併帶上 engine）。
COPY app ./app
COPY engine ./engine
COPY shared ./shared
RUN uv sync --frozen --no-dev

# 詞卡發音喇叭（Piper TTS）：下載固定語音 en_US-amy-medium，
# 與 engine/media/dict_audio.py 的 _resolve_model() fallback 檔名對齊。
RUN uv run python -m piper.download_voices --download-dir /app/voices en_US-amy-medium

# ---- runtime：乾淨小 image，只搬 .venv 與原始碼 ----
FROM python:3.12-slim AS runtime

# 用非 root 跑，降低風險
RUN useradd --create-home --uid 10001 appuser
WORKDIR /app

ENV PATH="/app/.venv/bin:$PATH" \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PORT=8080 \
    PIPER_VOICE_MODEL=/app/voices/en_US-amy-medium.onnx

COPY --from=builder --chown=appuser:appuser /app/.venv ./.venv
COPY --from=builder --chown=appuser:appuser /app/app ./app
COPY --from=builder --chown=appuser:appuser /app/engine ./engine
COPY --from=builder --chown=appuser:appuser /app/shared ./shared
COPY --from=builder --chown=appuser:appuser /app/voices ./voices

# ── Zeabur Self-host 部署專用 ──
# 把 scripts/ + db/migrations/ 帶進 image；啟動時由 app/main.py lifespan event 跑
# migrations（idempotent），不用 entrypoint shell — Zeabur runtime log driver 不抓
# PID 1 stdout，改在 main process（uvicorn / worker）裡 logger 印一定進 Zeabur log。
COPY --chown=appuser:appuser scripts ./scripts
COPY --chown=appuser:appuser db ./db

USER appuser
EXPOSE 8080

# 啟動入口 = uvicorn（lifespan event 內 _run_migrations_on_startup 跑 migrations）。
CMD ["sh", "-c", "uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8080}"]
