# Backup sidecar image（alpine + dcron + postgresql-client + aws-cli v2）
# Build context = backend/
# 用法：見 zeabur-template.yaml 的 `backup` 服務

FROM alpine:3.19

RUN apk add --no-cache \
    bash \
    postgresql16-client \
    aws-cli \
    curl && \
    curl -fsSL "https://github.com/jacobdaddio/dcron/releases/download/v0.1.0/dcron-static" \
      -o /usr/local/bin/dcron && \
    chmod +x /usr/local/bin/dcron

# 跑 backup 時區：容器啟動設 TZ 後，dcron 讀 local time
ENV TZ=Asia/Taipei

COPY deploy/backup/backup.sh /usr/local/bin/backup.sh
RUN chmod +x /usr/local/bin/backup.sh

COPY deploy/backup/backup.crontab /etc/crontabs/root
RUN chmod 600 /etc/crontabs/root

# 開機即跑 dcron，前景；Zeabur 看到 process 活著，視為 service healthy
ENTRYPOINT ["/usr/local/bin/dcron", "/etc/crontabs/root"]

# 健康：依稀給 Zeabur 看；備份任務是離峰，跑不跑正無所謂
HEALTHCHECK NONE
