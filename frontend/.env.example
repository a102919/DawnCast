# DawnCast 前端環境變數

# Vite 載入優先序（從高到低）：
#   1. process.env 中的 VITE_* 變數（shell / CI 注入）
#   2. `.env.[mode].local`  →  本機個人 override（gitignored）
#   3. `.env.[mode]`       →  該 mode 共用設定（.env.production 已 commit，.env.development 待補）
#   4. `.env.local`        →  本機個人共用 override（gitignored）
#   5. `.env`              →  共用 base（建議留空，避免不小心滲進 prod build）
#
# 注意：generic `.env` 在所有 mode 都會被載入；prod build 仍會讀它。
#      所以每個 VITE_* 都應該明確在 .env.production 設定值，prod 才不會誤帶本機 dev 值。

# ── 必填（依 mode） ──────────────────────────────────────
# dev（本機 vite dev server）：用相對路徑，靠 vite.config.ts 的 /api proxy 轉送到 localhost:8000
# prod（npm run build）：實際 API host，bake 進 bundle 不可事後改
VITE_API_BASE_URL=

# 切真實後端 API 模式（false = 接真後端）。mock 模式時 VITE_API_BASE_URL 可留空。
VITE_USE_MOCK=true

# Supabase（browser-public，靠 RLS 控管權限；anon key 不是 secret）
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── 設定範例 ─────────────────────────────────────────────
# dev（寫在 .env）：
#   VITE_API_BASE_URL=/api
#   VITE_USE_MOCK=false
#   VITE_SUPABASE_URL=https://xxx.supabase.co
#   VITE_SUPABASE_ANON_KEY=eyJ...
#
# prod（寫在 .env.production，已 commit）：
#   VITE_API_BASE_URL=https://dawncast-api.fly.dev   # 或 custom domain 如 api.dawncast.app
#   VITE_USE_MOCK=false
#   VITE_SUPABASE_URL=...
#   VITE_SUPABASE_ANON_KEY=...
